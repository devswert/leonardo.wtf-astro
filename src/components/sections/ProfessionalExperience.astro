---
import { getCollection, type CollectionEntry } from "astro:content";

import JobExperienceList from "../JobExperienceList.tsx";
import SideProjectCard from "../SideProjectCard.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const jobs: Array<CollectionEntry<"jobs">> = (
  await getCollection("jobs")
).reverse();

const sideProjets: Array<CollectionEntry<"sideProjects">> = (
  await getCollection("sideProjects")
).reverse();

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const jobItems = jobs.map((job) => ({
  id: job.id,
  company: job.data.company,
  position: job.data.position,
  timeFrame: job.data.timeFrame
    ? t(job.data.timeFrame as Parameters<typeof t>[0])
    : undefined,
  description: t(job.data.description as Parameters<typeof t>[0]),
  tools: job.data.tools,
}));
---

<div class="text-brand-green px-5">
  <h2 class="font-hornbill text-4xl text-center mb-5">
    • <br />
    {t("experiences.professionalTitle")}
  </h2>

  <JobExperienceList client:load jobs={jobItems} />

  <h2 class="font-hornbill text-4xl text-center mt-12">
    • <br />
    {t("experiences.sideProjectsTitle")}
  </h2>

  {
    sideProjets.map((project) => (
      <SideProjectCard
        company={project.data.company}
        date={t(project.data.date as Parameters<typeof t>[0])}
        description={t(project.data.description as Parameters<typeof t>[0])}
        tools={project.data.tools}
      />
    ))
  }
</div>
